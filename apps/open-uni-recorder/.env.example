# Open University credentials
OPENU_USERNAME=your_username
OPENU_PASSWORD=your_password
OPENU_ID=your_id

# API keys
# GROQ_API_KEY is required — used for both transcription (Whisper) and summarization (LLaMA)
GROQ_API_KEY=your_groq_key_here
# GEMINI_API_KEY is optional — enables Gemini as a fallback summarization backend
GEMINI_API_KEY=your_gemini_key_here

# Whisper backend (default: groq-whisper)
WHISPER_BACKEND=groq-whisper   # groq-whisper | nodejs-whisper
# Optional: seed Whisper with domain-specific terms to improve Hebrew/English accuracy
WHISPER_PROMPT=הרצאה אקדמית. עשוי להכיל מונחים טכניים באנגלית.
# Parallel transcription requests (keep at 2 on Groq free tier)
WHISPER_CONCURRENCY=2          # increase to 3-4 only if not on free tier

# Summarization backend (default: gemini)
SUMMARIZE_BACKEND=gemini       # groq | gemini | ollama
# Groq models for summarization
GROQ_CHUNK_MODEL=llama-3.1-8b-instant
GROQ_MERGE_MODEL=llama-3.3-70b-versatile

# Misc
WHISPER_MODEL=small            # tiny | base | small | medium | large (nodejs-whisper only)
OUTPUT_LANG=he                 # he = Hebrew output, en = English

# Email delivery — optional, skip silently if unset
GMAIL_USER=sender@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
NOTIFY_EMAIL=you@gmail.com
